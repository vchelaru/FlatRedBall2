<Project>
  <!--
    Precompiled Apos.Shapes shader XNBs.

    Apos.Shapes ships an .fx shader that must be compiled by the MonoGame/KNI content pipeline.
    On macOS and Linux, this requires Wine. To avoid that dependency, we ship precompiled XNBs
    for known platforms and skip Apos.Shapes' built-in shader compilation.

    Unknown platforms fall back to normal compilation (Apos.Shapes' own MSBuild targets handle
    it): a non-DesktopGL MonoGame target (e.g. WindowsDX) matches neither platform section below.

    The Apos.Shapes PACKAGE version is centralized in AposShapes.props (sibling file) as
    $(AposShapesVersion) — see that file for the rule on rebuilding these XNBs after a bump.

    ALLOWLIST: Only platforms with a verified precompiled XNB in this directory are listed.
    To add a new platform:
      1. Build a sample on that platform so the content pipeline compiles apos-shapes.xnb
      2. Copy the resulting .xnb into a new subfolder here (e.g. DirectX/)
      3. Add a platform section below, following the DesktopGL / BlazorGL pattern
      4. Update ShapesBatch.AposShapesVersion (C# const) to match $(AposShapesVersion)

    NOTE: the two platforms are wired DIFFERENTLY on purpose — read each section's comment.
    KNI's platform property is known during .props evaluation; MonoGame's is NOT.
  -->

  <PropertyGroup>
    <_FRB2PrecompiledShadersDir>$(MSBuildThisFileDirectory)</_FRB2PrecompiledShadersDir>
  </PropertyGroup>

  <!--
    ===========================================================================
    KNI BlazorGL

    $(KniPlatform) is set in KNI's buildTransitive *.props, which import BEFORE
    the project body. So it is already resolved when this .props evaluates, and
    the KNI path can safely gate on it in a <PropertyGroup>.

    KNI's props already added a KniContentReference (the compile trigger) before
    we ran, so SkipAposShapeContent by itself is too late — we also remove that
    reference explicitly.
    ===========================================================================
  -->
  <PropertyGroup Condition="'$(KniPlatform)' == 'BlazorGL'">
    <_FRB2HasPrecompiledAposShapes>true</_FRB2HasPrecompiledAposShapes>
    <_FRB2AposShapesPlatformDir>BlazorGL</_FRB2AposShapesPlatformDir>
    <SkipAposShapeContent>true</SkipAposShapeContent>
  </PropertyGroup>

  <ItemGroup Condition="'$(_FRB2HasPrecompiledAposShapes)' == 'true' and '$(KniPlatform)' != ''">
    <KniContentReference Remove="$(AposShapesPath)" />
  </ItemGroup>

  <!--
    Copy the precompiled XNB to wwwroot/Content/ so Blazor's static asset pipeline
    serves it. Uses a Copy target (not a Content item) to avoid conflicting with
    Blazor's auto-discovered wwwroot assets.
  -->
  <Target Name="_FRB2CopyPrecompiledAposShapesToWwwroot"
          Condition="'$(_FRB2HasPrecompiledAposShapes)' == 'true' and '$(KniPlatform)' != ''"
          BeforeTargets="GenerateStaticWebAssetsManifest;AssignTargetPaths">
    <Copy SourceFiles="$(_FRB2PrecompiledShadersDir)$(_FRB2AposShapesPlatformDir)\apos-shapes.xnb"
          DestinationFolder="$(MSBuildProjectDirectory)\wwwroot\Content\"
          SkipUnchangedFiles="true" />
  </Target>

  <!--
    ===========================================================================
    MonoGame DesktopGL  —  READ THIS BEFORE "SIMPLIFYING" IT TO A <PropertyGroup>

    Do NOT gate this on <PropertyGroup Condition="'$(MonoGamePlatform)' == 'DesktopGL'">.
    $(MonoGamePlatform) is set in MonoGame.Framework.DesktopGL's *.targets, which
    import AFTER the project body. This .props is imported within the project body,
    so during property evaluation $(MonoGamePlatform) is still EMPTY here, and a
    property-group gate on it silently no-ops.

    That was issue #666: with a dead gate the precompiled xnb never got copied,
    Apos.Shapes fell back to compiling its .fx, and every desktop build broke on
    macOS/Linux because that compile needs Wine. Windows hid it (it compiles the
    shader natively, no Wine), and the templates only "worked" because each set
    <MonoGamePlatform> manually before the import — a per-csproj line every new
    project had to remember, and all the samples forgot.

    Fix: read $(MonoGamePlatform) only where it resolves to its FINAL value — item
    conditions and target conditions, both evaluated after all properties/imports.
    This also frees consumer .csproj files from having to pre-set <MonoGamePlatform>.
    ===========================================================================
  -->

  <!-- Copy the precompiled XNB into the build output's Content/ folder. -->
  <ItemGroup Condition="'$(MonoGamePlatform)' == 'DesktopGL'">
    <Content Include="$(_FRB2PrecompiledShadersDir)DesktopGL\apos-shapes.xnb">
      <Link>Content\apos-shapes.xnb</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

  <!-- Skip Apos.Shapes' own MGCB shader compile (the Wine trigger) by removing its
       content reference right before MGCB collects references. A target is required
       because the equivalent property (SkipAposShapeContent) can't be set from a
       property-group gate here — see the note above. -->
  <Target Name="_FRB2SkipAposShapesContentDesktopGL"
          Condition="'$(MonoGamePlatform)' == 'DesktopGL'"
          BeforeTargets="CollectContentReferences">
    <ItemGroup>
      <MonoGameContentReference Remove="$(AposShapesPath)" />
    </ItemGroup>
  </Target>

</Project>
