<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:svg="clr-namespace:Avalonia.Svg.Skia;assembly=Svg.Controls.Skia.Avalonia">
    <!-- Phase 6 (#630) + Phase 7 (#644): style classes shared by AnimationEditor.App and
         AnimationEditor.Browser. Icon-dependent .plus/.minus moved here in Phase 7; ButtonSpinner
         ControlTheme lives in ThemeIconResources.axaml (ResourceDictionary, not Styles root). -->

    <!-- Folder-style TreeViews (#770 follow-up): FilesPanelControl and ProjectPanelControl both
         browse a folder tree and both hide the default chevron in favor of a click-to-toggle
         folder icon (VS Code style), shared here so the two don't duplicate the selector.
         Scoped to TreeView.folder-tree so the ANIMATIONS tree (chains/frames) is unaffected. -->
    <Style Selector="TreeView.folder-tree TreeViewItem /template/ Panel#PART_ExpandCollapseChevronContainer">
        <Setter Property="Width" Value="0" />
        <Setter Property="IsVisible" Value="False" />
    </Style>
    <Style Selector="TreeView.folder-tree TreeViewItem:empty /template/ Panel#PART_ExpandCollapseChevronContainer">
        <Setter Property="Width" Value="0" />
        <Setter Property="IsVisible" Value="False" />
    </Style>

    <!-- Compact buttons: override FluentTheme MinHeight so small +/- buttons aren't stretched -->
    <Style Selector="Button.compact">
        <Setter Property="MinHeight" Value="0"/>
        <Setter Property="MinWidth" Value="0"/>
        <Setter Property="Padding" Value="0"/>
    </Style>
    <!-- Flanker buttons: sit inside a bordered field on left/right of a value (Grid, Zoom, Speed) -->
    <Style Selector="Button.flanker">
        <Setter Property="MinHeight" Value="0"/>
        <Setter Property="MinWidth" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="CornerRadius" Value="0"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource InkMid}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
    </Style>
    <Style Selector="Button.flanker /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="Transparent"/>
    </Style>
    <Style Selector="Button.flanker:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource BgHover}"/>
    </Style>
    <Style Selector="Button.flanker:pressed /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource BgActive}"/>
    </Style>
    <!-- NumericUpDown: compact, no spinners by default. Set ShowButtonSpinner="True" individually where needed. -->
    <Style Selector="NumericUpDown">
        <Setter Property="ShowButtonSpinner" Value="False"/>
        <Setter Property="MinHeight" Value="0"/>
        <Setter Property="FontSize" Value="11"/>
    </Style>
    <!-- Strip the Fluent TextBox inner border inside ButtonSpinner so only the outer border is visible. -->
    <Style Selector="ButtonSpinner TextBox">
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Padding" Value="0"/>
    </Style>
    <!-- Disabled buttons: dim so the user can tell they are unavailable -->
    <Style Selector="Button:disabled">
        <Setter Property="Opacity" Value="0.35" />
    </Style>
    <!-- Toolbar/inspector text ToggleButtons (Move, Magic Wand, Grid, Onion Skin, Origin,
         Bounding Box, Guides, Interpolate, Flip H/V/D, ...): FluentTheme's default ToggleButton
         MinHeight (~32) and vertical Padding clip text descenders (e.g. the "g" in "Magic")
         once a fixed Height="26" is applied, because the squeeze happens inside the button's
         own rounded-corner clip. Originally patched per-button (#501/#697-style); centralized
         here so new toolbar toggles pick it up via Classes="toolbarToggle" instead of repeating
         the two-setter override. -->
    <Style Selector="ToggleButton.toolbarToggle">
        <Setter Property="Height" Value="26"/>
        <Setter Property="MinHeight" Value="0"/>
        <Setter Property="Padding" Value="10,0"/>
    </Style>
    <!-- Icon-based +/- buttons: render SVG from file so path data lives in one place only -->
    <Style Selector="Button.plus">
        <Setter Property="ContentTemplate">
            <DataTemplate>
                <svg:Svg Width="10" Height="10"
                         Path="avares://AnimationEditor.Views/Assets/icons/svg/IconPlus.svg"
                         CurrentColor="{DynamicResource IconInk}" />
            </DataTemplate>
        </Setter>
    </Style>
    <Style Selector="Button.minus">
        <Setter Property="ContentTemplate">
            <DataTemplate>
                <svg:Svg Width="10" Height="10"
                         Path="avares://AnimationEditor.Views/Assets/icons/svg/IconMinus.svg"
                         CurrentColor="{DynamicResource IconInk}" />
            </DataTemplate>
        </Setter>
    </Style>
</Styles>
