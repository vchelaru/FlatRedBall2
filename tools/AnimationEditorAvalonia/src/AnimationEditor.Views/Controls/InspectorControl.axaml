<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AnimationEditor.Views.Controls.InspectorControl">
    <!--
        Phase 9 (#649): sectioned headers matching desktop MainWindow's inline inspector naming
        (COORDINATES/TIMING/TRANSFORM/TEXTURE/COLOR), see docs/BROWSER_SIDEBAR_TABS_DECISION.md.
        This control is NOT shared with desktop (MainWindow has its own separate, much richer
        inline inspector directly in MainWindow.axaml; confirmed by grep, no source reference to
        InspectorControl anywhere in AnimationEditor.App), so this is a visual-parity restyle of
        the browser's own simpler control, matching desktop's section taxonomy rather than its
        exact field set.
    -->
    <StackPanel Spacing="0">
        <TextBlock x:Name="NoSelectionPanel" x:FieldModifier="Public"
                   Text="No selection." IsVisible="False"
                   Foreground="{DynamicResource InkDim}"
                   FontStyle="Italic" HorizontalAlignment="Center" Margin="0,12,0,0" />

        <StackPanel x:Name="FramePanel" x:FieldModifier="Public" IsVisible="False" Spacing="0">
            <Border BorderBrush="{DynamicResource LineBrush}" BorderThickness="0,0,0,1" Padding="12,8,12,10">
                <StackPanel Spacing="8">
                    <TextBlock x:Name="CoordinatesHeader" x:FieldModifier="Public"
                               Text="COORDINATES" FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource InkMid}" />
                    <!-- Kept for existing tests that assert on the summary string. -->
                    <TextBlock x:Name="FrameCoordinatesText" x:FieldModifier="Public" IsVisible="False" />
                    <WrapPanel>
                        <Grid ColumnDefinitions="14,*" MinWidth="86" Margin="0,0,8,4">
                            <TextBlock Text="X" VerticalAlignment="Center"
                                       Foreground="{DynamicResource InkMid}" FontSize="11" FontWeight="SemiBold" />
                            <NumericUpDown x:Name="FramePixelXInput" x:FieldModifier="Public" Grid.Column="1"
                                           MinWidth="66" Minimum="-16384" Maximum="16384" Increment="1" />
                        </Grid>
                        <Grid ColumnDefinitions="14,*" MinWidth="86" Margin="0,0,8,4">
                            <TextBlock Text="Y" VerticalAlignment="Center"
                                       Foreground="{DynamicResource InkMid}" FontSize="11" FontWeight="SemiBold" />
                            <NumericUpDown x:Name="FramePixelYInput" x:FieldModifier="Public" Grid.Column="1"
                                           MinWidth="66" Minimum="-16384" Maximum="16384" Increment="1" />
                        </Grid>
                    </WrapPanel>
                    <WrapPanel>
                        <Grid ColumnDefinitions="14,*" MinWidth="86" Margin="0,0,8,4">
                            <TextBlock Text="W" VerticalAlignment="Center"
                                       Foreground="{DynamicResource InkMid}" FontSize="11" FontWeight="SemiBold" />
                            <NumericUpDown x:Name="FramePixelWInput" x:FieldModifier="Public" Grid.Column="1"
                                           MinWidth="66" Minimum="1" Maximum="16384" Increment="1" />
                        </Grid>
                        <Grid ColumnDefinitions="14,*" MinWidth="86" Margin="0,0,8,4">
                            <TextBlock Text="H" VerticalAlignment="Center"
                                       Foreground="{DynamicResource InkMid}" FontSize="11" FontWeight="SemiBold" />
                            <NumericUpDown x:Name="FramePixelHInput" x:FieldModifier="Public" Grid.Column="1"
                                           MinWidth="66" Minimum="1" Maximum="16384" Increment="1" />
                        </Grid>
                    </WrapPanel>
                </StackPanel>
            </Border>
            <Border BorderBrush="{DynamicResource LineBrush}" BorderThickness="0,0,0,1" Padding="12,8,12,10">
                <StackPanel Spacing="8">
                    <TextBlock x:Name="TimingHeader" x:FieldModifier="Public"
                               Text="TIMING" FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource InkMid}" />
                    <TextBlock x:Name="FrameLengthText" x:FieldModifier="Public" IsVisible="False" />
                    <Grid ColumnDefinitions="Auto,*" MinWidth="120">
                        <TextBlock Text="Length (s)" VerticalAlignment="Center" Margin="0,0,8,0"
                                   Foreground="{DynamicResource InkMid}" FontSize="11" />
                        <NumericUpDown x:Name="FrameLengthInput" x:FieldModifier="Public" Grid.Column="1"
                                       Minimum="0.001" Maximum="60" Increment="0.01" FormatString="0.###" />
                    </Grid>
                </StackPanel>
            </Border>
            <Border BorderBrush="{DynamicResource LineBrush}" BorderThickness="0,0,0,1" Padding="12,8,12,10">
                <StackPanel Spacing="8">
                    <TextBlock x:Name="TransformHeader" x:FieldModifier="Public"
                               Text="TRANSFORM" FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource InkMid}" />
                    <TextBlock x:Name="FrameOffsetText" x:FieldModifier="Public" IsVisible="False" />
                    <TextBlock x:Name="FrameFlipText" x:FieldModifier="Public" IsVisible="False" />
                    <WrapPanel>
                        <Grid ColumnDefinitions="Auto,*" MinWidth="100" Margin="0,0,8,4">
                            <TextBlock Text="Rel X" VerticalAlignment="Center" Margin="0,0,6,0"
                                       Foreground="{DynamicResource InkMid}" FontSize="11" />
                            <NumericUpDown x:Name="FrameRelXInput" x:FieldModifier="Public" Grid.Column="1"
                                           MinWidth="66" Increment="1" FormatString="0.###" />
                        </Grid>
                        <Grid ColumnDefinitions="Auto,*" MinWidth="100" Margin="0,0,8,4">
                            <TextBlock Text="Rel Y" VerticalAlignment="Center" Margin="0,0,6,0"
                                       Foreground="{DynamicResource InkMid}" FontSize="11" />
                            <NumericUpDown x:Name="FrameRelYInput" x:FieldModifier="Public" Grid.Column="1"
                                           MinWidth="66" Increment="1" FormatString="0.###" />
                        </Grid>
                    </WrapPanel>
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <ToggleButton x:Name="FrameFlipHToggle" x:FieldModifier="Public"
                                      Classes="toolbarToggle" Content="Flip H" />
                        <ToggleButton x:Name="FrameFlipVToggle" x:FieldModifier="Public"
                                      Classes="toolbarToggle" Content="Flip V" />
                        <ToggleButton x:Name="FrameFlipDToggle" x:FieldModifier="Public"
                                      Classes="toolbarToggle" Content="Flip D" />
                    </StackPanel>
                </StackPanel>
            </Border>
            <Border BorderBrush="{DynamicResource LineBrush}" BorderThickness="0,0,0,1" Padding="12,8,12,10">
                <StackPanel Spacing="4">
                    <TextBlock x:Name="TextureHeader" x:FieldModifier="Public"
                               Text="TEXTURE" FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource InkMid}" />
                    <TextBlock x:Name="FrameTextureText" x:FieldModifier="Public" />
                </StackPanel>
            </Border>
            <Border Padding="12,8,12,10">
                <StackPanel Spacing="8">
                    <TextBlock x:Name="ColorHeader" x:FieldModifier="Public"
                               Text="COLOR" FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource InkMid}" />
                    <!-- Kept for existing tests that assert on the summary string. -->
                    <TextBlock x:Name="FrameColorText" x:FieldModifier="Public" IsVisible="False" />
                    <Grid ColumnDefinitions="44,*">
                        <TextBlock Text="Mode" VerticalAlignment="Center"
                                   Foreground="{DynamicResource InkMid}" FontSize="11" />
                        <ComboBox x:Name="FrameColorModeCombo" x:FieldModifier="Public" Grid.Column="1"
                                  HorizontalAlignment="Stretch">
                            <ComboBoxItem>None</ComboBoxItem>
                            <ComboBoxItem>Multiply</ComboBoxItem>
                            <ComboBoxItem>Add</ComboBoxItem>
                        </ComboBox>
                    </Grid>
                    <WrapPanel>
                        <Grid ColumnDefinitions="14,*" MinWidth="86" Margin="0,0,8,4">
                            <TextBlock Text="R" VerticalAlignment="Center"
                                       Foreground="{DynamicResource Accent}" FontSize="11" FontWeight="SemiBold" />
                            <NumericUpDown x:Name="FrameRedInput" x:FieldModifier="Public" Grid.Column="1"
                                           MinWidth="66" Minimum="0" Maximum="255" Increment="1" FormatString="0" />
                        </Grid>
                        <Grid ColumnDefinitions="14,*" MinWidth="86" Margin="0,0,8,4">
                            <TextBlock Text="G" VerticalAlignment="Center"
                                       Foreground="{DynamicResource Ok}" FontSize="11" FontWeight="SemiBold" />
                            <NumericUpDown x:Name="FrameGreenInput" x:FieldModifier="Public" Grid.Column="1"
                                           MinWidth="66" Minimum="0" Maximum="255" Increment="1" FormatString="0" />
                        </Grid>
                        <Grid ColumnDefinitions="14,*" MinWidth="86" Margin="0,0,8,4">
                            <TextBlock Text="B" VerticalAlignment="Center"
                                       Foreground="{DynamicResource AccentCool}" FontSize="11" FontWeight="SemiBold" />
                            <NumericUpDown x:Name="FrameBlueInput" x:FieldModifier="Public" Grid.Column="1"
                                           MinWidth="66" Minimum="0" Maximum="255" Increment="1" FormatString="0" />
                        </Grid>
                        <Grid ColumnDefinitions="14,*" MinWidth="86" Margin="0,0,8,4">
                            <TextBlock Text="A" VerticalAlignment="Center"
                                       Foreground="{DynamicResource InkMid}" FontSize="11" FontWeight="SemiBold" />
                            <NumericUpDown x:Name="FrameAlphaInput" x:FieldModifier="Public" Grid.Column="1"
                                           MinWidth="66" Minimum="0" Maximum="255" Increment="1" FormatString="0" />
                        </Grid>
                    </WrapPanel>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Editable (#610 follow-up): committed on LostFocus/Enter via CommitRectProps, routed
             through AppCommands.SetRectProps, same commit-boundary pattern MainWindow uses
             for its own PropRect* fields. One TRANSFORM section, matching desktop's flat
             Name/X/Y/ScaleX/ScaleY field list (no further subdivision on desktop either). -->
        <StackPanel x:Name="RectPanel" x:FieldModifier="Public" IsVisible="False" Spacing="0">
            <Border Padding="12,8,12,10">
                <StackPanel Spacing="8">
                    <TextBlock Text="TRANSFORM" FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource InkMid}" />
                    <TextBox x:Name="RectNameBox" x:FieldModifier="Public" PlaceholderText="Name" />
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="X:" VerticalAlignment="Center" />
                        <NumericUpDown x:Name="RectXInput" x:FieldModifier="Public" Increment="1" FormatString="0.###" />
                        <TextBlock Text="Y:" VerticalAlignment="Center" />
                        <NumericUpDown x:Name="RectYInput" x:FieldModifier="Public" Increment="1" FormatString="0.###" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="Scale X:" VerticalAlignment="Center" />
                        <NumericUpDown x:Name="RectScaleXInput" x:FieldModifier="Public" Increment="1" Minimum="0" FormatString="0.###" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="Scale Y:" VerticalAlignment="Center" />
                        <NumericUpDown x:Name="RectScaleYInput" x:FieldModifier="Public" Increment="1" Minimum="0" FormatString="0.###" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>

        <StackPanel x:Name="CirclePanel" x:FieldModifier="Public" IsVisible="False" Spacing="0">
            <Border Padding="12,8,12,10">
                <StackPanel Spacing="8">
                    <TextBlock Text="TRANSFORM" FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource InkMid}" />
                    <TextBox x:Name="CircleNameBox" x:FieldModifier="Public" PlaceholderText="Name" />
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="X:" VerticalAlignment="Center" />
                        <NumericUpDown x:Name="CircleXInput" x:FieldModifier="Public" Increment="1" FormatString="0.###" />
                        <TextBlock Text="Y:" VerticalAlignment="Center" />
                        <NumericUpDown x:Name="CircleYInput" x:FieldModifier="Public" Increment="1" FormatString="0.###" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="Radius:" VerticalAlignment="Center" />
                        <NumericUpDown x:Name="CircleRadiusInput" x:FieldModifier="Public" Increment="1" Minimum="0" FormatString="0.###" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </StackPanel>
</UserControl>
