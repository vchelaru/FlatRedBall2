<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AnimationEditor.App.App"
             RequestedThemeVariant="Dark">
             <!-- "Dark" is only the bootstrap default for the first paint; MainWindow applies the
                  user's persisted choice (Light / Dark / Follow System) during construction. -->

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://AnimationEditor.Views/Theming/ThemeTokens.axaml" />
                <!-- Phase 7 (#644): ButtonSpinner ControlTheme with shared SVG chevrons. -->
                <ResourceInclude Source="avares://AnimationEditor.Views/Theming/ThemeIconResources.axaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />
        <!-- ColorView/ColorPicker (Avalonia.Controls.ColorPicker) ships its control templates
             in a separate theme dictionary; without this include the controls have no template
             and render at zero size. Must match the FluentTheme above. -->
        <StyleInclude Source="avares://Avalonia.Controls.ColorPicker/Themes/Fluent/Fluent.xaml" />
        <StyleInclude Source="avares://AnimationEditor.Views/Theming/ThemeStyles.axaml" />
    </Application.Styles>
</Application>
