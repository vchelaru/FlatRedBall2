{
  // Slots: "ground" (on ground), "air" (airborne), "afterDoubleJump" (reserved, not yet wired).
  // Omitted fields fall back to engine defaults. Omitted slots are left untouched on the behavior.
  "movement": {
    "ground": {
      "MaxSpeedX": 150,             // world units/sec
      "AccelerationTimeX": 0.5,     // seconds to reach MaxSpeedX from rest (0 = instant)
      "DecelerationTimeX": 0.25,    // seconds to stop from MaxSpeedX (0 = instant)
      "Gravity": 700,               // downward acceleration (must be positive)
      "MaxFallSpeed": 800,          // terminal velocity (must be > 0)

      // Jump: pick ONE mode per slot. Using both derived and raw in the same slot is an error.
      //
      // Derived mode (preferred) — specify desired heights, engine computes the physics:
      "minJumpHeight": 24,          // tap jump height (world units). Required for derived mode.
      "maxJumpHeight": 64           // hold jump height. Optional — omit for fixed-height jump.
                                    // Must be >= minJumpHeight. Cannot specify without minJumpHeight.
      //
      // Raw mode (escape hatch) — set physics directly:
      // "JumpVelocity": 300,       // upward velocity on jump press
      // "JumpApplyLength": 0.15,   // seconds to sustain jump velocity
      // "JumpApplyByButtonHold": true  // if true, releasing early cuts the jump short

      // Slope tuning (all optional, defaults shown):
      // "SlopeSnapDistance": 16,           // max downward snap distance (0 disables)
      // "SlopeSnapMaxAngleDegrees": 60,    // surfaces steeper than this won't snap
      // "UphillFullSpeedSlope": 0,         // degrees below which uphill = full speed
      // "UphillStopSpeedSlope": 60,        // degrees at which uphill speed = 0
      // "DownhillFullSpeedSlope": 0,       // degrees below which downhill = normal speed
      // "DownhillMaxSpeedSlope": 60,       // degrees at which full downhill multiplier applies
      // "DownhillMaxSpeedMultiplier": 1.5, // peak downhill speed boost (1 = disabled)

      // "CanFallThroughOneWayCollision": true  // false disables Down+Jump drop-through
    },
    "air": {
      "MaxSpeedX": 150,
      "AccelerationTimeX": 0.5,
      "DecelerationTimeX": 0.25,
      "Gravity": 700,
      "MaxFallSpeed": 800,
      "minJumpHeight": 24,
      "maxJumpHeight": 64
    }
  }
}
