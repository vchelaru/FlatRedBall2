{
  "$schema": "http://json.schemastore.org/template",
  "author": "FlatRedBall2",
  "classifications": ["Games", "MonoGame", "FlatRedBall2"],
  "identity": "FlatRedBall2.Templates.Desktop",
  "name": "FlatRedBall2 Desktop Game",
  "shortName": "frb2-desktop",
  "sourceName": "MyGame",
  "preferNameDirectory": true,
  "tags": {
    "language": "C#",
    "type": "project"
  },
  "symbols": {
    "IncludeStarterContent": {
      "type": "parameter",
      "datatype": "bool",
      "defaultValue": "true",
      "description": "Include starter Content assets (animation chains, base TMX, platformer/topdown configs). Pass --IncludeStarterContent false to start with an empty Content folder."
    }
  },
  "sources": [
    {
      "modifiers": [
        {
          "condition": "(!IncludeStarterContent)",
          "exclude": [ "MyGame.Desktop/Content/*/**" ]
        }
      ]
    }
  ]
}
